# =============================================================================
# Lumeo — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=lumeo
POSTGRES_USER=lumeo
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=11603

# ---- Symfony ----
APP_SECRET=changeThisToARandomString
APP_ENV=dev

# ---- JWT (Lexik) ----
JWT_PASSPHRASE=changeme

# ---- Mercure ----
MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
MERCURE_PORT=11602
MERCURE_PUBLIC_URL=http://localhost:11602/.well-known/mercure

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx

# ---- Ports ----
FRONT_PORT=11600
BACK_PORT=11601

# ---- Frontend URLs (injected at build/runtime) ----
NUXT_PUBLIC_API_BASE=http://localhost:11601/api
NUXT_PUBLIC_MERCURE_HUB=http://localhost:11602/.well-known/mercure
NUXT_PUBLIC_SERVER_BASE=http://localhost:11601

# ---- Production only ----
FRONT_BASE_URL=https://lumeo.jeremyduc.dev
CORS_ALLOW_ORIGIN=^https?://(lumeo\.jeremyduc\.dev|www\.lumeo\.jeremyduc\.dev)$

# ---- Docker images (prod CI/CD) ----
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=your-github-user/lumeo
IMAGE_TAG=latest
