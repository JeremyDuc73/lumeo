# =============================================================================
# Lumeo Frontend — Development Dockerfile (Nuxt 3 HMR)
# =============================================================================
FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cache layer)
COPY front/package.json front/package-lock.json ./
RUN npm ci

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
